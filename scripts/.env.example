# ──────────────────────────────────────────────────────────────────────
# Crego Internal Docs — Deploy Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp scripts/.env.example scripts/.env
# ──────────────────────────────────────────────────────────────────────

# S3 bucket name (no s3:// prefix)
S3_BUCKET=internal.assets.crego.ai

# S3 key prefix (path inside the bucket). Leave empty to deploy to bucket root.
S3_PREFIX=

# AWS region for the S3 bucket
AWS_REGION=ap-south-1

# CloudFront distribution ID (required for cache invalidation)
# Find it: aws cloudfront list-distributions --query "DistributionList.Items[].{Id:Id,Domain:DomainName}" --output table
CLOUDFRONT_DISTRIBUTION_ID=

# (Optional) AWS CLI profile name. Leave blank to use default credentials.
# AWS_PROFILE=
